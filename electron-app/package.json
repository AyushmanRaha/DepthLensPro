{
  "name": "depthlens-pro",
  "version": "4.0.0",
  "description": "AI-Powered 2D to 3D Depth Map Generation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dmg --arm64 --x64",
    "build:win": "electron-builder --win nsis --x64",
    "build:all": "electron-builder --mac dmg --arm64 --x64 --win nsis --x64 --linux AppImage --x64",
    "start:dev": "electron .",
    "backend:smoke": "npm run backend:live && npm run backend:devices && npm run backend:health",
    "verify:resources": "node scripts/verify-resources.js",
    "backend:live": "node -e \"fetch('http://127.0.0.1:8765/live').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "backend:health": "node -e \"fetch('http://127.0.0.1:8765/health').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "backend:devices": "node -e \"fetch('http://127.0.0.1:8765/devices').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "build:linux": "electron-builder --linux AppImage --x64"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.ayushmanraha.depthlens-pro",
    "productName": "DepthLens Pro",
    "copyright": "Copyright \u00a9 2025 Ayushman Raha",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": false,
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "../venv",
        "to": "venv",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "../frontend",
        "to": "frontend"
      }
    ],
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
