{
  "name": "depthlens-pro",
  "version": "4.0.0",
  "description": "AI-Powered 2D to 3D Depth Map Generation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "npm run clean:dist && npm run build:mac:arm64 && npm run scan:apps",
    "build:win": "npm run build:win:arm64",
    "build:all": "npm run build:mac:arm64 && npm run build:win:arm64 && npm run build:linux:arm64",
    "start:dev": "electron .",
    "backend:smoke": "npm run smoke:backend",
    "verify:resources": "node scripts/verify-resources.js",
    "backend:live": "node -e \"fetch('http://127.0.0.1:8765/live').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "backend:health": "node -e \"fetch('http://127.0.0.1:8765/health').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "backend:devices": "node -e \"fetch('http://127.0.0.1:8765/devices').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "build:linux": "npm run build:linux:arm64",
    "build:mac:arm64": "electron-builder --mac dmg --arm64",
    "build:win:arm64": "electron-builder --win nsis --arm64",
    "build:linux:arm64": "electron-builder --linux AppImage --arm64",
    "build:mac:x64": "node scripts/unsupported-arch.js",
    "build:mac:universal": "node scripts/unsupported-arch.js",
    "build:win:x64": "node scripts/unsupported-arch.js",
    "build:linux:x64": "node scripts/unsupported-arch.js",
    "kill:backend": "node scripts/backend-lifecycle.js kill",
    "smoke:backend": "node scripts/backend-lifecycle.js smoke",
    "clean:dist": "node scripts/clean-dist.js",
    "scan:apps": "node scripts/scan-apps.js",
    "clean:install": "node scripts/clean-install.js",
    "clean:spotlight": "node scripts/clean-spotlight.js",
    "reinstall:mac": "node scripts/reinstall-mac.js",
    "backend:ready": "node -e \"fetch('http://127.0.0.1:8765/ready').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "test": "node test-security-policy.js",
    "doctor": "cd .. && python3 scripts/doctor.py --doctor-only",
    "setup": "cd .. && python3 scripts/doctor.py",
    "setup:mac": "cd .. && scripts/setup-macos.sh",
    "setup:linux": "cd .. && scripts/setup-linux.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File ../scripts/setup-windows.ps1",
    "verify:onnx": "../venv/bin/python ../backend/scripts/export_onnx.py --validate-only --all"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.ayushmanraha.depthlens-pro",
    "productName": "DepthLens Pro",
    "copyright": "Copyright \u00a9 2025 Ayushman Raha",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "../venv",
        "to": "venv",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "../frontend",
        "to": "frontend"
      },
      {
        "from": "../models",
        "to": "models",
        "filter": [
          "**/*",
          "**/.*",
          "!**/.DS_Store",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "dependencies": {
    "electron-log": "^5.4.4"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
