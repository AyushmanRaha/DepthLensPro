#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
if [[ ! -f setup-manifest.json ]]; then
  echo "Setup manifest missing. Run ./scripts/setup first." >&2
  exit 1
fi
python3 - <<'PY'
import json, platform, sys
from pathlib import Path
from scripts.platform_support import require_supported, normalize_arch, normalize_os
m=json.loads(Path('setup-manifest.json').read_text())
t=require_supported(platform.system(), platform.machine())
if m.get('platform') != t.platform_key or m.get('arch') != t.arch:
    raise SystemExit(f"Setup manifest target {m.get('platform')} {m.get('arch')} does not match current target {t.platform_key} {t.arch}; re-run ./scripts/setup on this machine.")
print(f"Build target verified: {t.label}")
PY
(cd electron-app && npm run verify:resources:native)
case "$(python3 - <<'PY'
from scripts.platform_support import current_target
print(current_target().platform_key + ':' + current_target().arch)
PY
)" in
  darwin:arm64) (cd electron-app && npm run build:mac:arm64) ;;
  win32:arm64) (cd electron-app && npm run build:win:arm64) ;;
  win32:x64) (cd electron-app && npm run build:win:x64) ;;
  linux:arm64) (cd electron-app && npm run build:linux:arm64) ;;
  linux:x64) (cd electron-app && npm run build:linux:x64) ;;
  *) echo "Unsupported target" >&2; exit 1 ;;
esac
