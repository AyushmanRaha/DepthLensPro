{
  "name": "depthlens-pro-root",
  "private": true,
  "scripts": {
    "doctor": "python3 scripts/doctor.py --doctor-only",
    "setup": "python3 scripts/doctor.py",
    "setup:mac": "scripts/setup-macos.sh",
    "setup:linux": "scripts/setup-linux.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "build:mac:arm64": "scripts/build-native-macos.sh",
    "build:linux:arm64": "scripts/build-native-linux.sh --arch arm64",
    "build:win:arm64": "powershell -ExecutionPolicy Bypass -File scripts/build-native-windows.ps1 -Arch arm64",
    "verify:resources": "cd electron-app && npm run verify:resources",
    "verify:onnx": "venv/bin/python backend/scripts/export_onnx.py --validate-only --all",
    "backend:dev": "venv/bin/python -m uvicorn backend.app:app --host 127.0.0.1 --port 8765",
    "frontend:dev": "cd electron-app && npm run start:dev",
    "stop:backend": "cd electron-app && npm run kill:backend",
    "setup:mac:onnx": "scripts/setup-macos.sh --with-onnx --onnx-models all",
    "setup:linux:onnx": "scripts/setup-linux.sh --with-onnx --onnx-models all",
    "setup:win:onnx": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1 --with-onnx --onnx-models all",
    "build:mac:arm64:onnx": "scripts/build-native-macos.sh --with-onnx --onnx-models all",
    "build:win:x64": "powershell -ExecutionPolicy Bypass -File scripts/build-native-windows.ps1 -Arch x64",
    "build:win:arm64:onnx": "powershell -ExecutionPolicy Bypass -File scripts/build-native-windows.ps1 -Arch arm64 -WithOnnx -OnnxModels all",
    "build:win:x64:onnx": "powershell -ExecutionPolicy Bypass -File scripts/build-native-windows.ps1 -Arch x64 -WithOnnx -OnnxModels all",
    "build:linux:x64": "scripts/build-native-linux.sh --arch x64",
    "build:linux:arm64:onnx": "scripts/build-native-linux.sh --arch arm64 --with-onnx --onnx-models all",
    "build:linux:x64:onnx": "scripts/build-native-linux.sh --arch x64 --with-onnx --onnx-models all",
    "launch:mac": "scripts/launch-macos.sh",
    "launch:win": "powershell -ExecutionPolicy Bypass -File scripts/launch-windows.ps1",
    "launch:linux": "scripts/launch-linux.sh",
    "verify:onnx:required": "cd electron-app && node scripts/verify-resources.js --root-kind repo --mode native --onnx require-all --models all .."
  }
}
