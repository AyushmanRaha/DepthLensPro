export PYTHONPATH=/workspace/DepthLensPro
export CODEX_ENV=1
export CI=1
export TESTING=1
export DEPTHLENS_SKIP_WARMUP=1
export DEPTHLENS_DISABLE_MODEL_DOWNLOADS=1
export DEPTHLENS_CACHE_BACKEND=memory
export DEPTHLENS_REDIS_URL=
export TORCH_HOME=/workspace/.cache/torch
export HF_HOME=/workspace/.cache/huggingface
export XDG_CACHE_HOME=/workspace/.cache
export ONNX_WEIGHTS_DIR=/workspace/DepthLensPro/models/onnx
export ORT_INTRA_OP_NUM_THREADS=2
export ORT_INTER_OP_NUM_THREADS=1
export INFERENCE_MAX_CONCURRENCY=2
export PYTHONUNBUFFERED=1
export PIP_DISABLE_PIP_VERSION_CHECK=1
export PIP_NO_CACHE_DIR=1
export NPM_CONFIG_FUND=false
export NPM_CONFIG_AUDIT=false
export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
export PUPPETEER_SKIP_DOWNLOAD=true
