# DepthLens Pro local defaults
# Copy this to .env for local development if needed.

CODEX_ENV=0
TESTING=0
DEPTHLENS_SKIP_WARMUP=0
DEPTHLENS_DISABLE_MODEL_DOWNLOADS=0

DEPTHLENS_CACHE_BACKEND=memory
DEPTHLENS_REDIS_URL=

ONNX_WEIGHTS_DIR=./models/onnx
ORT_INTRA_OP_NUM_THREADS=2
ORT_INTER_OP_NUM_THREADS=1

INFERENCE_MAX_CONCURRENCY=2
MAX_UPLOAD_SIZE_MB=20
